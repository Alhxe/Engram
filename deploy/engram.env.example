# Copy to engram.env and fill in. engram.env is gitignored — never commit it.

# --- CORS: exact origin of the frontend (Cloudflare Pages custom domain) ---
# Add the *.pages.dev preview origin too if you want preview deploys to work.
ENGRAM_CORS_ORIGINS=https://engram.alexperezalvarez.dev

# --- Secrets (generate with the commands below) ---
# JWT signing secret, base64, >= 32 bytes:  openssl rand -base64 48
ENGRAM_JWT_SECRET=CHANGE_ME
# AES-256 key to encrypt stored AI provider keys, base64 32 bytes: openssl rand -base64 32
# WARNING: rotating this makes previously stored provider keys unreadable.
ENGRAM_AI_ENCRYPTION_KEY=CHANGE_ME

# --- Scheduled full-vault backups (optional) ---
ENGRAM_BACKUP_ENABLED=true
ENGRAM_BACKUP_CRON=0 0 3 * * *
ENGRAM_BACKUP_KEEP=7

# The Cloudflare Tunnel runs natively on the host (see ~/.cloudflared/config.yml),
# not as a container, so no tunnel token is needed here.
